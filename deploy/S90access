#!/bin/sh
### BEGIN INIT INFO
# Provides:          access
# Required-Start:    $remote_fs $syslog
# Required-Stop:     $remote_fs $syslog
# Default-Start:     S
# Default-Stop:
# Short-Description: Access Control App (demo_rga_v4l2)
### END INIT INFO

BASE=/data/access
START_SH=$BASE/current/start.sh
PIDFILE=$BASE/run/app.pid

start() {
    mkdir -p "$BASE/run" "$BASE/logs"

    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "[S90access] already running: pid=$(cat "$PIDFILE")"
        return 0
    fi

    if [ ! -x "$START_SH" ]; then
        echo "[S90access] missing start script: $START_SH"
        return 1
    fi

    echo "[S90access] starting via: $START_SH"
    nohup "$START_SH" >/dev/null 2>&1 &
    return 0
}

stop() {
    if [ -f "$PIDFILE" ]; then
        PID=$(cat "$PIDFILE")
        echo "[S90access] stopping: pid=$PID"
        kill "$PID" 2>/dev/null || true

        i=0
        while [ $i -lt 30 ]; do
            if kill -0 "$PID" 2>/dev/null; then
                usleep 100000 2>/dev/null || sleep 0.1
                i=$((i+1))
            else
                break
            fi
        done

        if kill -0 "$PID" 2>/dev/null; then
            echo "[S90access] kill -9: pid=$PID"
            kill -9 "$PID" 2>/dev/null || true
        fi

        rm -f "$PIDFILE"
    else
        echo "[S90access] not running"
    fi
    return 0
}

status() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "[S90access] running: pid=$(cat "$PIDFILE")"
        return 0
    fi
    echo "[S90access] stopped"
    return 1
}

case "$1" in
  start) start ;;
  stop) stop ;;
  restart) stop; start ;;
  status) status ;;
  *)
    echo "Usage: $0 {start|stop|restart|status}"
    exit 1
    ;;
esac

exit 0
